# udev rule: grant the `plugdev` group read/write on the Jabra SPEAK 510
# (USB 0b0e:0422) hidraw node. The voice-bridge service runs as a user
# unit (not root) and the user is in plugdev — without this rule the
# default `root:root 0600` permissions block the bridge from opening
# /dev/hidraw*.
#
# The bridge keeps a single long-running reconnect loop on its own, so
# this rule does NOT trigger the service. It only sets permissions; the
# bridge picks up plug events from its 2 s reconnect poll.
#
# SUBSYSTEM=="hidraw" rather than "usb" so the rule fires *after*
# /dev/hidrawN exists — that's the node we need MODE/GROUP on.

ACTION=="add", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0b0e", ATTRS{idProduct}=="0422", GROUP="plugdev", MODE="0660"
